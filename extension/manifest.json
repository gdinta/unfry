{
  "manifest_version": 3,
  "name": "UnFry",
  "version": "0.1.0",
  "description": "Local activity sensing, forced micro-breaks, context-aware learning.",
  "permissions": ["tabs", "storage", "activeTab", "scripting", "alarms"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "src/background/index.ts", "type": "module" },
  "content_scripts": [
    { "matches": ["<all_urls>"], "js": ["src/content/scrapeContext.ts"], "run_at": "document_idle" },
    { "matches": ["<all_urls>"], "js": ["src/overlay/inject.tsx"], "run_at": "document_start" }
  ],
  "web_accessible_resources": [
    { "resources": ["src/overlay/inject.tsx", "assets/*"], "matches": ["<all_urls>"] }
  ],
  "action": { "default_popup": "src/popup/index.html", "default_title": "UnFry" },
  "icons": { "16": "public/icons/icon16.png", "48": "public/icons/icon48.png", "128": "public/icons/icon128.png" }
}
